{
  "name": "@ccg-labs/crawler",
  "version": "0.1.0",
  "description": "Site crawler for discovering all URLs and linked resources",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": { "crawl": "./dist/cli.js" },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "cheerio": "^1",
    "crawlee": "^3",
    "fast-xml-parser": "^4",
    "playwright": "^1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "@vitest/coverage-v8": "^2",
    "eslint": "^8",
    "typescript": "^5",
    "vitest": "^2"
  }
}
