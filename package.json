{
  "name": "@ccg-labs/crawler",
  "version": "0.1.0",
  "description": "Site crawler for discovering all URLs and linked resources",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "crawl": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "keywords": ["ccg-labs", "crawler", "seo", "typescript", "nodejs"],
  "repository": {
    "type": "git",
    "url": "https://github.com/CCG-Labs/crawler"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "tsc",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cheerio": "^1",
    "crawlee": "^3",
    "fast-xml-parser": "^4",
    "playwright": "^1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^7",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^8",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
